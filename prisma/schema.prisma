generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AppConfig {
  id                  Int      @id
  aiAutoReplyEnabled  Boolean  @default(true)
  aiApiUrl            String
  aiApiKey            String
  aiModel             String
  promptSystem        String   @db.Text
  waApiUrl            String
  waSessionId         String
  waToken             String
  waMasterKey         String
  mongodbUri          String
  mongodbDb           String
  ragCollection       String
  ragIndexName        String
  embeddingProvider   String
  embeddingApiKey     String
  embeddingModel      String
  embeddingDimensions String
  embeddingBaseUrl    String
  bytePlusApiKey      String   @default("")
  bytePlusBaseUrl     String   @default("https://ark.ap-southeast.bytepluses.com/api/v3")
  bytePlusImageModel  String   @default("seedream-4-5-251128")
  r2AccessKey         String   @default("")
  r2SecretKey         String   @default("")
  r2Bucket            String   @default("")
  r2Endpoint          String   @default("")
  r2PublicUrl         String   @default("")
  topicScoutSearchApiKey String @default("")
  topicScoutSearchUrl  String  @default("https://search.infoquest.bytepluses.com")
  topicScoutModelApiKey String @default("")
  topicScoutModelBaseUrl String @default("https://ark.ap-southeast.bytepluses.com/api/v3")
  topicScoutModel      String  @default("seed-2-0-mini-260215")
  topicScoutDefaultQuery String @default("tren terbaru hotel indonesia direct booking OTA website hotel AI customer service hospitality marketing")
  metaAppId           String   @default("")
  metaAppSecret       String   @default("")
  metaGraphVersion    String   @default("v23.0")
  metaFacebookPageId  String   @default("")
  metaFacebookPageName String  @default("")
  metaInstagramBusinessId String @default("")
  metaInstagramUsername String @default("")
  metaPageAccessToken String   @default("")
  metaPageTokenExpiresAt String @default("")
  threadsUserId        String   @default("")
  threadsUsername      String   @default("")
  threadsAccessToken   String   @default("")
  threadsTokenExpiresAt String  @default("")
  threadsApiVersion    String   @default("v1.0")
  threadsApiBaseUrl    String   @default("https://graph.threads.net")
  linkedinClientId    String   @default("")
  linkedinClientSecret String  @default("")
  linkedinRedirectUri String   @default("")
  linkedinAccessToken String   @default("")
  linkedinRefreshToken String  @default("")
  linkedinTokenExpiresAt String @default("")
  linkedinAuthorUrn   String   @default("")
  linkedinOrganizationUrn String @default("")
  linkedinApiVersion  String   @default("202504")
  autoPostEnabled     Boolean  @default(false)
  schedulerSecret     String   @default("")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model AdminUser {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model MessageLog {
  id        String   @id @default(uuid())
  fromPhone String
  message   String   @db.Text
  reply     String   @db.Text
  source    String
  status    String
  intent    String
  createdAt DateTime @default(now())
  error     String?  @db.Text

  @@index([createdAt])
  @@index([fromPhone])
}

model MemorySession {
  phone      String          @id
  summary    String          @default("") @db.Text
  lastActive DateTime
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  messages   MemoryMessage[]

  @@index([lastActive])
}

model MemoryMessage {
  id        String        @id @default(uuid())
  phone     String
  role      String
  content   String        @db.Text
  createdAt DateTime      @default(now())
  session   MemorySession @relation(fields: [phone], references: [phone], onDelete: Cascade)

  @@index([phone, createdAt])
}

model WebhookEvent {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  stage     String
  fromPhone String?
  message   String?  @db.Text
  reason    String?  @db.Text
  payload   Json?
  rawBody   String?  @db.Text
  headers   Json?

  @@index([createdAt])
  @@index([stage])
}
